"""
step2_analysis.ipynb  (run as a plain .py or paste cells into Jupyter)
=======================================================================
Runs glycan_contacts.py on 3AVE and 1GYA, merges results,
and produces exploratory visualisations.
"""

# ── Cell 1: Install + download ────────────────────────────────────────────────
# !pip install biopython pandas numpy matplotlib seaborn -q

import urllib.request, os
import matplotlib
matplotlib.use("Agg")  # must come before importing pyplot
import matplotlib.pyplot as plt

def fetch_pdb(pdb_id, folder="."):
    path = os.path.join(folder, f"{pdb_id}.pdb")
    if not os.path.exists(path):
        url = f"https://files.rcsb.org/download/{pdb_id}.pdb"
        urllib.request.urlretrieve(url, path)
        print(f"Downloaded {path}")
    else:
        print(f"Found existing {path}")
    return path

pdb_3ave = fetch_pdb("3AVE")
pdb_1gya = fetch_pdb("1GYA")


# ── Cell 2: Run the parser on both structures ─────────────────────────────────
from glycan_contacts import parse_contacts, summarise
import pandas as pd

df_3ave = parse_contacts(pdb_3ave, outer_cutoff=8.0)
df_1gya = parse_contacts(pdb_1gya, outer_cutoff=8.0)

summarise(df_3ave)
summarise(df_1gya)

# Merge into one master table for aim-2 analysis
df_all = pd.concat([df_3ave, df_1gya], ignore_index=True)
df_all.to_csv("step2_all_contacts.csv", index=False)
print(f"\nMaster table: {len(df_all)} rows → step2_all_contacts.csv")


# ── Cell 3: Interaction type bar chart ───────────────────────────────────────
import matplotlib.pyplot as plt
import matplotlib.ticker as mticker

COLORS = {
    "H-bond"        : "#185FA5",
    "Electrostatic" : "#993C1D",
    "CH-pi"         : "#3B6D11",
    "Hydrophobic"   : "#BA7517",
    "van der Waals" : "#534AB7",
}

fig, axes = plt.subplots(1, 2, figsize=(11, 4), sharey=False)

for ax, (df, label) in zip(axes, [(df_3ave, "3AVE – IgG1 Fc"),
                                    (df_1gya, "1GYA – CD2 adhesion")]):
    counts = df["interaction_type"].value_counts()
    colors = [COLORS.get(t, "#888") for t in counts.index]
    bars = ax.bar(counts.index, counts.values, color=colors, edgecolor="white",
                  linewidth=0.5, width=0.6)
    ax.set_title(label, fontsize=11, fontweight="normal", pad=8)
    ax.set_ylabel("Number of contacts", fontsize=9)
    ax.set_xlabel("")
    ax.tick_params(axis="x", labelsize=8, rotation=20)
    ax.tick_params(axis="y", labelsize=8)
    ax.spines[["top", "right"]].set_visible(False)
    ax.yaxis.set_major_locator(mticker.MaxNLocator(integer=True))
    for bar, val in zip(bars, counts.values):
        ax.text(bar.get_x() + bar.get_width()/2, bar.get_height() + 0.2,
                str(val), ha="center", va="bottom", fontsize=8)

fig.suptitle("Step 2 — Non-covalent glycan–protein contacts by interaction type",
             fontsize=11, y=1.02)
plt.tight_layout()
plt.savefig("step2_interaction_types.png", dpi=150, bbox_inches="tight")
plt.show()
print("Saved → step2_interaction_types.png")


# ── Cell 4: Distance distribution ────────────────────────────────────────────
import numpy as np

fig, ax = plt.subplots(figsize=(8, 4))

for itype, grp in df_all.groupby("interaction_type"):
    vals = grp["distance_A"]
    color = COLORS.get(itype, "#888")
    ax.hist(vals, bins=30, range=(1.8, 8.0), alpha=0.6,
            label=f"{itype} (n={len(vals)})", color=color, edgecolor="none")

# Reference lines for each cutoff
for label, cut, col in [
    ("H-bond 3.5 Å",       3.5, "#185FA5"),
    ("vdW 4.0 Å",          4.0, "#534AB7"),
    ("CH–pi 4.5 Å",        4.5, "#3B6D11"),
    ("Hydrophobic 5.0 Å",  5.0, "#BA7517"),
    ("Electrostatic 6.0 Å",6.0, "#993C1D"),
]:
    ax.axvline(cut, color=col, linewidth=0.8, linestyle="--", alpha=0.7)
    ax.text(cut + 0.05, ax.get_ylim()[1] * 0.85, label,
            color=col, fontsize=7, rotation=90, va="top")

ax.set_xlabel("Heavy-atom distance (Å)", fontsize=10)
ax.set_ylabel("Count", fontsize=10)
ax.set_title("Contact distance distribution — 3AVE + 1GYA combined", fontsize=10)
ax.legend(fontsize=8, frameon=False)
ax.spines[["top", "right"]].set_visible(False)
plt.tight_layout()
plt.savefig("step2_distance_dist.png", dpi=150, bbox_inches="tight")
plt.show()
print("Saved → step2_distance_dist.png")


# ── Cell 5: Heatmap — glycan residue vs protein residue contact counts ────────
import seaborn as sns

for df, label, fname in [
    (df_3ave, "3AVE – IgG1 Fc",         "step2_heatmap_3AVE.png"),
    (df_1gya, "1GYA – CD2 adhesion dom","step2_heatmap_1GYA.png"),
]:
    pivot = (df.groupby(["glycan_resname", "protein_resnum"])
               .size()
               .unstack(fill_value=0))

    fig, ax = plt.subplots(figsize=(max(8, pivot.shape[1]*0.35),
                                    max(4, pivot.shape[0]*0.6)))
    sns.heatmap(pivot, annot=True, fmt="d", cmap="Blues", linewidths=0.3,
                linecolor="#e0e0e0", ax=ax, cbar_kws={"shrink": 0.6})
    ax.set_title(f"{label}\nContact count: glycan residue × protein residue number",
                 fontsize=10, pad=10)
    ax.set_xlabel("Protein residue number", fontsize=9)
    ax.set_ylabel("Glycan residue (CCD)", fontsize=9)
    ax.tick_params(labelsize=8)
    plt.tight_layout()
    plt.savefig(fname, dpi=150, bbox_inches="tight")
    plt.show()
    print(f"Saved → {fname}")


# ── Cell 6: Spotlight on the known 3AVE contact (validation) ─────────────────
print("\n── 3AVE: NAG–Arg301 contact (aim-2 benchmark) ──")
spot = df_3ave[
    (df_3ave["glycan_resname"] == "NAG") &
    (df_3ave["protein_resname"] == "ARG") &
    (df_3ave["protein_resnum"] == 301)
]
if not spot.empty:
    print(spot[["glycan_atom", "protein_atom", "distance_A",
                "interaction_type"]].to_string(index=False))
    print("\n✓  Known NAG(O7)–Arg301(NE) H-bond recovered by parser.")
else:
    print("  Contact not found — check chain / residue numbering in 3AVE.pdb")

# ── Cell 7: Export per-structure summary CSVs ─────────────────────────────────
for df, pid in [(df_3ave, "3AVE"), (df_1gya, "1GYA")]:
    df.to_csv(f"{pid}_contacts.csv", index=False)
    print(f"Saved {pid}_contacts.csv  ({len(df)} rows)")

print("\nStep 2 complete.  Proceed to Step 3: variant overlay.")

